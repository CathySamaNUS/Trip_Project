{
  // Cloudflare Workers (Static Assets) config for the Vite-built SPA.
  // Pages 用户不需要这个文件；Workers 必须用它来声明 dist 目录 + SPA 路由 fallback。
  "$schema": "https://developers.cloudflare.com/schemas/wrangler/wrangler.schema.json",
  "name": "travelproject",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
